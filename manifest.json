{
  "manifest_version": 3,
  "name": "CleanTube TTV",
  "version": "1.0.0",
  "description": "Clean YouTube live stream view with Twitch chat panel",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
